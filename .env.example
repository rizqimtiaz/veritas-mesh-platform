# Veritas Mesh — environment variables
# Copy this file to .env.local and fill in the values you need.
# All variables are OPTIONAL — the app runs end-to-end with simulated on-chain
# verification if none are set.

# Public L2 RPC endpoint (e.g. Base Sepolia, Optimism Sepolia, Arbitrum Sepolia)
NEXT_PUBLIC_L2_RPC_URL=

# Deployed VeritasRegistry contract address on the L2 above
NEXT_PUBLIC_REGISTRY_ADDR=

# Server-side key used by /api/inference to route to a real decentralized GPU
# provider (Akash / Render / Bittensor). Leave blank for local simulation.
MESH_GATEWAY_KEY=

# Optional: WalletConnect project ID for connecting external wallets
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
